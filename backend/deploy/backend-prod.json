{
  "family": "backend-prod",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "tags": [
  ],
  "cpu": "256",
  "memory": "512",
  "taskRoleArn": "$TASK_ROLE_ARN",
  "executionRoleArn": "$TASK_ROLE_ARN",
  "containerDefinitions": [
    {
      "name": "app",
      "cpu": 256,
      "memory": 512,
      "memoryReservation": 256,
      "image": "$AWS_ECR_REGISTRY/webapp:prod",
      "essential": true,
      "command": [
        "npm", "run","start"
      ],
      "portMappings": [
        {
          "hostPort": 4000,
          "containerPort": 4000,
          "protocol": "tcp"
        }
      ],
      "secrets": [
        {
          "name": "POSTGRES_HOST",
          "valueFrom": "arn:aws:ssm:ap-southeast-2:298984097578:parameter/JKOS/POSTGRES_HOST"
        },
        {
          "name": "POSTGRES_PORT",
          "valueFrom": "arn:aws:ssm:ap-southeast-2:298984097578:parameter/JKOS/POSTGRES_PORT"
        },
        {
          "name": "POSTGRES_USER",
          "valueFrom": "arn:aws:ssm:ap-southeast-2:298984097578:parameter/JKOS/POSTGRES_USER"
        },
        {
          "name": "POSTGRES_PASSWORD",
          "valueFrom": "arn:aws:ssm:ap-southeast-2:298984097578:parameter/JKOS/POSTGRES_PASSWORD"
        },
        {
          "name": "POSTGRES_DB",
          "valueFrom": "arn:aws:ssm:ap-southeast-2:298984097578:parameter/JKOS/POSTGRES_DB"
        }
      ],
      "environment": [
        {
          "name": "NODE_ENV",
          "value": "production"
        },
        {
          "name": "API_HOST",
          "value": "https://d1cdm1glqbkaza.cloudfront.net/"
        }
      ]
    }
  ]
}
